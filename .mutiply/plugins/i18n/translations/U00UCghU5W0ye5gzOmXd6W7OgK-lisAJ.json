                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "\\u0412\\u044B\\u0431\\u0435\\u0440\\u0438\\u0442\\u0435, \\u043A\\u0430\\u043A\\u0438\\u0435 \\u0434\\u043D\\u0438 \\u043D\\u0435\\u0434\\u0435\\u043B\\u0438 \\u043E\\u0442\\u043E\\u0431\\u0440\\u0430\\u0436\\u0430\\u0442\\u044C: \\u0447\\u0435\\u0442\\u043D\\u044B\\u0435 \\u0434\\u043D\\u0438 (\\u043D\\u0430\\u043F\\u0440\\u0438\\u043C\\u0435\\u0440, \\u0432\\u0442\\u043E\\u0440\\u043D\\u0438\\u043A, \\u0447\\u0435\\u0442\\u0432\\u0435\\u0440\\u0433, \\u0441\\u0443\\u0431\\u0431\\u043E\\u0442\\u0430), \\u043D\\u0435\\u0447\\u0435\\u0442\\u043D\\u044B\\u0435 \\u0434\\u043D\\u0438 (\\u043D\\u0430\\u043F\\u0440\\u0438\\u043C\\u0435\\u0440, \\u043F\\u043E\\u043D\\u0435\\u0434\\u0435\\u043B\\u044C\\u043D\\u0438\\u043A, \\u0441\\u0440\\u0435\\u0434\\u0430, \\u043F\\u044F\\u0442\\u043D\\u0438\\u0446\\u0430, \\u0432\\u043E\\u0441\\u043A\\u0440\\u0435\\u0441\\u0435\\u043D\\u044C\\u0435), \\xAB\\u041D\\u0435\\u0442\\xBB (\\u043D\\u0435 \\u043E\\u0442\\u043E\\u0431\\u0440\\u0430\\u0436\\u0430\\u0442\\u044C \\u0434\\u043D\\u0438) \\u0438\\u043B\\u0438 \\xAB\\u0412\\u0441\\u0435\\xBB (\\u043E\\u0442\\u043E\\u0431\\u0440\\u0430\\u0436\\u0430\\u0442\\u044C \\u0432\\u0441\\u0435 \\u0441\\u0435\\u043C\\u044C \\u0434\\u043D\\u0435\\u0439). \n\\u0434\\u043D\\u0438 \\u043D\\u0435\\u0434\\u0435\\u043B\\u0438).",
