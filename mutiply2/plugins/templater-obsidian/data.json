{
  "command_timeout": 6,
  "templates_folder": "Templates",
  "templates_pairs": [
    [
      "tianqi",
      "curl -H \"Accept-Language: zh-CN\" \"wttr.in/zhengzhou?format=%c+%F0%9F%8C%A1%t\""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": true,
  "enable_system_commands": true,
  "shell_path": "",
  "user_scripts_folder": "88-Template/script/template",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "000 life os/00task",
      "template": "模板/每日笔记.md"
    },
    {
      "folder": "004 注会",
      "template": "模板/笔记常用模版.md"
    },
    {
      "folder": "003 中级",
      "template": "模板/笔记常用模版.md"
    },
    {
      "folder": "002 司法考试",
      "template": "模板/法考模版.md"
    },
    {
      "folder": "000 life os/播客生活",
      "template": "模板/播客模版.md"
    },
    {
      "folder": "000 life os/日常周记",
      "template": "模板/每日笔记.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "88-Template/tp/tp_foldermoc-Include-subfolders.md",
    "88-Template/tp/tp-插件启停模板.md"
  ],
  "startup_templates": [],
  "intellisense_render": 1,
  "enable_ribbon_icon": true
}